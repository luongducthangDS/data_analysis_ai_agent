# ── LLM Provider (chọn 1, ưu tiên theo thứ tự: Groq → Gemini → HuggingFace) ──
# LLM_PROVIDER=groq   # force provider: groq | gemini | huggingface

# Groq (recommended — free, no credit card)
# Lấy key tại: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (fallback)
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# HuggingFace (tertiary fallback)
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest
HF_BASE_URL=https://router.huggingface.co/v1

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8000
# DATA_DIR: root folder for uploads/ and reports/ subdirectories.
# On Railway: set this to the mount path of your persistent volume (e.g. /data).
# Locally: leave unset → defaults to "data/" relative to project root.
# DATA_DIR=/data
